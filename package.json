    "@techstark/opencv-js": "^4.12.0-release.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.2.1",
    "dompurify": "^3.3.1",
    "eruda": "^3.4.3",
    "exceljs": "^4.1.1",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
